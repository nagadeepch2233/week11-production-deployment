def main():
    lib = Library()
    
    while True:
        # Show the production dashboard every time we return to menu
        print_dashboard(lib)
        
        print("MENU: [1]Add Book [2]Add Member [3]Borrow [4]Return [5]Search [6]Exit")
        choice = input("Select Action: ").strip()
        
        if choice == "1":
            lib.add_book(Book(input("Title: "), input("Author: "), input("ISBN: ")))
        elif choice == "2":
            lib.add_member(Member(input("Name: "), input("ID: ")))
        elif choice == "3":
            isbn = input("ISBN: ")
            mid = input("Member ID: ")
            # Basic logic within main for brevity
            book = lib.books.get(isbn)
            mem = lib.members.get(mid)
            if book and mem and book.available:
                book.available = False
                book.due = (datetime.now() + timedelta(days=LOAN_DAYS)).strftime("%Y-%m-%d")
                mem.borrowed.append(isbn)
                lib.save()
                print(f"Success! Due: {book.due}")
            else:
                print("Error: Book unavailable or ID invalid.")
        elif choice == "4":
            # Logic for return (similar to borrow)
            pass 
        elif choice == "5":
            query = input("Search term: ").lower()
            results = [b for b in lib.books.values() if query in b.title.lower()]
            for r in results: print(f"-> {r.title} ({'In' if r.available else 'Out'})")
        elif choice == "6":
            print("Deployment terminating safely...")
            break
        else:
            print("Invalid command.")

if __name__ == "__main__":
    main()
