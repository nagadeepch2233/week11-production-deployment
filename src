import os
import json
from datetime import datetime, timedelta

LOAN_DAYS = int(os.getenv("LOAN_DAYS", 14))
DATA_FILE = os.getenv("DATA_FILE", "library.json")

class Book:
    def __init__(self, title, author, isbn, available=True, due=None):
        self.title = title
        self.author = author
        self.isbn = isbn
        self.available = available
        self.due = due

    def to_dict(self):
        return vars(self)

class Member:
    def __init__(self, name, id, borrowed=None):
        self.name = name
        self.id = id
        self.borrowed = borrowed if borrowed is not None else []

    def to_dict(self):
        return vars(self)

class Library:
    def __init__(self):
        self.books = {}
        self.members = {}
        self.load()

    def save(self):
        data = {
            "books": {k: v.to_dict() for k, v in self.books.items()},
            "members": {k: m.to_dict() for k, m in self.members.items()}
        }
        with open(DATA_FILE, "w") as f:
            json.dump(data, f, indent=4)

    def load(self):
        if os.path.exists(DATA_FILE):
            with open(DATA_FILE, "r") as f:
                data = json.load(f)
                self.books = {k: Book(**v) for k, v in data.get("books", {}).items()}
                self.members = {k: Member(**v) for k, v in data.get("members", {}).items()}

    def stats(self):
        total = len(self.books)
        available = sum(1 for b in self.books.values() if b.available)
        borrowed = total - available
        members_count = len(self.members)
        return total, available, borrowed, members_count

